# config.example.env — kimi-remote 自托管统一配置
# 用法:cp config.example.env config.env,逐项填写(带 * 必填,其余有默认)。
# 原则:你的账号/服务器/密钥全部只存在你自己的机器上,与其他部署完全隔离。

# ============ 网关(你的云服务器) ============
# * 对外域名(证书由安装器用 certbot 自动签发)
GATEWAY_DOMAIN=kimi.example.com
# * H5 登录密码(明文只用于安装时生成 scrypt 哈希,不留存)
LOGIN_PASSWORD=change-me-strong
# JWT 签名密钥(留空则安装器随机生成 64 位 hex)
JWT_SECRET=
# 网关监听(默认 127.0.0.1:8080,由本机 nginx 反代)
GATEWAY_PORT=8080

# ============ 设备(你的 Mac/工作站,跑 Kimi/Codex 的那台) ============
# Kimi Code 本地 server 端口(默认 58627;安装器会自动 `kimi web` 拉起并驻留)
KIMI_PORT=58627
# Kimi server token(默认自动读 ~/.kimi-code/server.token,无需手填)
KIMI_TOKEN=
# adapter(设备前门)端口(默认 58629)
ADAPTER_PORT=58629
# fleet 探针端口(默认 58628,机群页读面;不需要机群页可关)
FLEET_PORT=58628
FLEET_TOKEN=            # 留空则安装器随机生成

# ============ 隧道(设备 → 网关) ============
# * 网关服务器 SSH(免密需先配好:ssh-copy-id user@server)
TUNNEL_SSH=user@your.server.ip
# 隧道转发端口映射(默认三端口:kimi/adapter/fleet)
TUNNEL_PORTS=58627:58627,58629:58629,58628:58628

# ============ 可选:Claude Code·壳 接管 ============
# claude CLI 接管需要一条模型通道(Anthropic 兼容端点)。
# 例:自建 litellm / 月之暗面 anthropic 端点 / 其他兼容网关;不配置则该功能自动隐藏
CLAUDE_BASE_URL=
CLAUDE_AUTH_TOKEN=
CLAUDE_MODEL=m3

# ============ 可选:Codex 接管 ============
# 走本机 codex CLI 的 OpenAI 登录态,无需配置;无额度时自动如实报错

# ============ 可选:告警 ============
# 探针异常告警通道:飞书 bot(填了才启用)
LARK_BOT_USER_OPEN_ID=
# 或通用 webhook(POST JSON)
ALERT_WEBHOOK_URL=

# ============ 部署档(多环境) ============
# 正式/测试双通道:测试通道域名(留空则不启用)
TEST_DOMAIN=

# ============ 可选:证书 ============
# certbot 联系邮箱(留空则安装器跳过 HTTPS 证书签发,只配 HTTP)
CERTBOT_EMAIL=
